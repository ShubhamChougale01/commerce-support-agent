# Optional: leave blank to use the Claude Code subscription via claude-agent-sdk
# (run `claude login` first). Set a real key for production. See README.
ANTHROPIC_API_KEY=

# Zoho Desk — OAuth Self Client (api-console.zoho.com)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORG_ID=
# data centre your Zoho account lives on: com | in | eu | com.au
ZOHO_DC=com
# the support mailbox replies are sent from (must be configured in Zoho Desk)
ZOHO_FROM_EMAIL=
# Zoho Desk team IDs for escalation routing
ZOHO_TEAM_FRAUD=
ZOHO_TEAM_LEGAL=
ZOHO_TEAM_REFUNDS=
ZOHO_TEAM_GENERAL=

# Medusa.js — self-hosted (see docker-compose.medusa.yml)
MEDUSA_URL=http://localhost:9000
MEDUSA_API_KEY=

SUPABASE_URL=
SUPABASE_KEY=
SLACK_WEBHOOK_URL=

# shared secret for the Zoho Desk workflow webhook
DESK_WEBHOOK_SECRET=

# Port the support agent listens on (default 8001; 8000 is taken by the storefront)
PORT=8001

# Integration tests only (pytest -m integration)
TEST_EMAIL=
TEST_TICKET_ID=
